---
import Mark from '../components/Mark.astro';
import { site } from '../content/site';
import Base from '../layouts/Base.astro';
---

<Base title={`Not found — ${site.name}`} noindex>
  <main id="main-content" class="not-found" tabindex="-1">
    <div class="not-found__inner">
      <a class="not-found__brand" href="/" aria-label="Boomich home">
        <Mark small size={36} />
        <span>Boomich</span>
      </a>
      <h1>{site.notFound.heading}</h1>
      <p>{site.notFound.body}</p>
      <a class="button-ghost" href={site.notFound.cta.href}
        ><span>{site.notFound.cta.label}</span></a
      >
    </div>
  </main>
</Base>

<style>
  .not-found {
    display: grid;
    min-height: 100svh;
    padding: var(--gutter);
    place-items: center;
  }

  .not-found__inner {
    width: min(100%, 42rem);
  }

  .not-found__brand {
    display: inline-flex;
    gap: 0.65rem;
    align-items: center;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
  }

  h1,
  p {
    margin: 0;
  }

  h1 {
    max-width: 11ch;
    margin-top: clamp(3rem, 9vw, 7rem);
    font-family: var(--font-display);
    font-size: var(--type-display-size);
    font-weight: var(--type-display-weight);
    letter-spacing: var(--type-display-tracking);
    line-height: var(--type-display-leading);
    text-wrap: balance;
  }

  p {
    max-width: 36ch;
    margin-top: 1.5rem;
    color: var(--color-ink-secondary);
  }

  .button-ghost {
    margin-top: 2rem;
  }
</style>
