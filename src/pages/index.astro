---
import Capabilities from '../components/Capabilities.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import Nav from '../components/Nav.astro';
import ScrollReveals from '../components/ScrollReveals.astro';
import SmoothScroll from '../components/SmoothScroll.astro';
import Studio from '../components/Studio.astro';
import Work from '../components/Work.astro';
import { site } from '../content/site';
import Base from '../layouts/Base.astro';
---

<Base
  title={`${site.name} — ${site.description}`}
  description={site.metaDescription}
>
  <Nav />
  <main id="main-content" tabindex="-1">
    <Hero />
    <Capabilities />
    <Work />
    <Studio />
    <Contact />
  </main>
  <Footer />
  <SmoothScroll />
  <ScrollReveals />
</Base>
