---
import Hero from '../components/Hero.astro';
import Nav from '../components/Nav.astro';
import { site } from '../content/site';
import Base from '../layouts/Base.astro';
---

<Base title={`${site.name} — ${site.description}`}>
  <Nav />
  <main id="top">
    <Hero />
    <section
      id="capabilities"
      class="phase-placeholder"
      aria-label="What we build"
    >
    </section>
    <section id="work" class="phase-placeholder" aria-label="Shipped work">
    </section>
    <section id="studio" class="phase-placeholder" aria-label="Studio">
    </section>
    <section id="contact" class="phase-placeholder" aria-label="Contact">
    </section>
  </main>
</Base>

<style>
  .phase-placeholder {
    min-height: 1px;
  }
</style>
