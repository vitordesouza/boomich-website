---
import '../styles/base.css';

import { site } from '../content/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = site.name, description = site.description } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, 'https://boomich.pt');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="oklch(0.24 0.030 130)" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link
      rel="preload"
      href="/fonts/panchang-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/switzer-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
