---
import { site } from '../content/site';
---

<section id="work" class="work" aria-labelledby="work-heading">
  <div class="work__inner">
    <h2 id="work-heading">{site.work.heading}</h2>
    <div class="work__list">
      {
        site.work.items.map((item) => (
          <article class="work__item">
            <p>{item.domain}</p>
            <h3>{item.statement}</h3>
          </article>
        ))
      }
    </div>
    <p class="work__footnote">{site.work.footnote}</p>
  </div>
</section>

<style>
  .work {
    padding: clamp(112px, 15vw, 220px) var(--gutter);
    border-top: 1px solid var(--color-line);
  }

  .work__inner {
    width: min(100%, var(--maxw));
    margin: 0 auto;
  }

  h2,
  h3,
  p {
    margin: 0;
  }

  h2,
  h3 {
    font-family: var(--font-display);
    font-weight: var(--type-headline-weight);
    letter-spacing: var(--type-headline-tracking);
  }

  h2 {
    font-size: var(--type-headline-size);
    line-height: var(--type-headline-leading);
  }

  .work__list {
    margin-top: clamp(4rem, 10vw, 9.5rem);
    border-top: 1px solid var(--color-line);
  }

  .work__item {
    padding: clamp(2.5rem, 7vw, 6rem) 0;
    border-bottom: 1px solid var(--color-line);
  }

  .work__item p {
    margin-bottom: 0.9rem;
    color: var(--color-ink-secondary);
    font-size: 1rem;
    font-weight: 500;
  }

  .work__item h3 {
    max-width: 22ch;
    font-size: var(--type-headline-size);
    line-height: var(--type-headline-leading);
  }

  .work__footnote {
    max-width: 62ch;
    margin-top: 1.25rem;
    color: var(--color-ink-faint);
    font-size: 0.875rem;
    line-height: 1.5;
  }
</style>
