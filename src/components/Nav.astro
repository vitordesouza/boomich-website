---
import { site } from '../content/site';
import Mark from './Mark.astro';
---

<header id="top" class="site-nav" data-site-nav>
  <nav class="site-nav__inner" aria-label="Primary navigation">
    <a class="site-nav__brand" href="#top" aria-label="Boomich home">
      <Mark small size={24} />
      <span>Boomich</span>
    </a>
    <div class="site-nav__desktop-links">
      {site.navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </div>
    <a class="button-ghost site-nav__cta" href={site.navCta.href}
      ><span>{site.navCta.label}</span></a
    >
    <button
      class="site-nav__menu-button"
      type="button"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="site-menu"
    >
      Menu
    </button>
  </nav>
  <div class="site-nav__progress" aria-hidden="true" data-scroll-progress>
    {
      Array.from({ length: 48 }, (_, index) => (
        <span data-progress-tick={index} />
      ))
    }
  </div>
  <div class="site-nav__mobile-menu" id="site-menu" data-menu hidden>
    <button
      class="site-nav__close"
      type="button"
      data-menu-close
      aria-label="Close menu">Close</button
    >
    <div class="site-nav__mobile-links">
      {
        site.navigation.map((item, index) => (
          <a href={item.href} style={`--menu-link-index: ${index}`}>
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</header>

<script>
  const nav = document.querySelector<HTMLElement>('[data-site-nav]');
  const toggle = nav?.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const menu = nav?.querySelector<HTMLElement>('[data-menu]');
  const close = nav?.querySelector<HTMLButtonElement>('[data-menu-close]');
  const progressTicks = nav?.querySelectorAll<HTMLElement>(
    '[data-progress-tick]',
  );
  let opener: HTMLElement | null = null;
  let closeTimer = 0;
  let progressFrame = 0;
  let filledTicks = -1;

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  );

  const updateProgress = (): void => {
    progressFrame = 0;
    if (!progressTicks?.length) return;
    const availableScroll =
      document.documentElement.scrollHeight - window.innerHeight;
    const progress = availableScroll > 0 ? window.scrollY / availableScroll : 0;
    const nextFilledTicks = Math.round(
      Math.min(1, Math.max(0, progress)) * progressTicks.length,
    );
    if (nextFilledTicks === filledTicks) return;
    progressTicks.forEach((tick, index) => {
      tick.classList.toggle('is-filled', index < nextFilledTicks);
    });
    filledTicks = nextFilledTicks;
  };

  const setScrolled = (): void => {
    nav?.classList.toggle('site-nav--scrolled', window.scrollY > 24);
    if (!progressFrame)
      progressFrame = window.requestAnimationFrame(updateProgress);
  };
  const focusable = (): HTMLElement[] =>
    menu
      ? Array.from(
          menu.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
        )
      : [];
  const closeMenu = (): void => {
    if (!menu || !toggle) return;
    if (menu.hidden || menu.classList.contains('is-closing')) return;
    toggle.setAttribute('aria-expanded', 'false');
    document.body.classList.remove('menu-open');
    menu.classList.add('is-closing');
    window.clearTimeout(closeTimer);
    const finishClose = (): void => {
      menu.hidden = true;
      menu.classList.remove('is-closing');
      opener?.focus();
    };
    closeTimer = window.setTimeout(
      finishClose,
      prefersReducedMotion.matches ? 0 : 150,
    );
  };
  const openMenu = (): void => {
    if (!menu || !toggle) return;
    window.clearTimeout(closeTimer);
    menu.classList.remove('is-closing');
    opener = toggle;
    menu.hidden = false;
    toggle.setAttribute('aria-expanded', 'true');
    document.body.classList.add('menu-open');
    close?.focus();
  };

  toggle?.addEventListener('click', () =>
    menu?.hidden ? openMenu() : closeMenu(),
  );
  close?.addEventListener('click', closeMenu);
  menu?.addEventListener('click', (event) => {
    if ((event.target as HTMLElement).closest('a')) closeMenu();
  });
  document.addEventListener('keydown', (event) => {
    if (!menu || menu.hidden) return;
    if (event.key === 'Escape') {
      closeMenu();
      return;
    }
    if (event.key !== 'Tab') return;
    const items = focusable();
    const first = items[0];
    const last = items[items.length - 1];
    if (!first || !last) return;
    if (event.shiftKey && document.activeElement === first) {
      event.preventDefault();
      last.focus();
    } else if (!event.shiftKey && document.activeElement === last) {
      event.preventDefault();
      first.focus();
    }
  });
  window.addEventListener('scroll', setScrolled, { passive: true });
  window.addEventListener('resize', setScrolled, { passive: true });
  setScrolled();
</script>

<style>
  .site-nav {
    position: sticky;
    z-index: 10;
    top: 0;
  }

  /* Glass lives on a pseudo so the nav never becomes the containing
     block for the fixed-position mobile menu (backdrop-filter would). */
  .site-nav::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    background: oklch(0.24 0.03 130 / 0.92);
    backdrop-filter: saturate(0.82) brightness(0.86);
    content: '';
  }

  .site-nav::after {
    position: absolute;
    right: 0;
    bottom: 3px;
    left: 0;
    height: 1px;
    background: var(--color-line);
    content: '';
    opacity: 0;
    transition: opacity 160ms var(--ease-ui);
  }

  .site-nav--scrolled::after {
    opacity: 1;
  }

  .site-nav__inner {
    display: flex;
    align-items: center;
    width: min(100%, calc(var(--maxw) + var(--gutter) * 2));
    min-height: 72px;
    margin: 0 auto;
    padding-inline: var(--gutter);
  }

  .site-nav__progress {
    position: absolute;
    right: var(--gutter);
    bottom: 0;
    left: var(--gutter);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 4px;
  }

  .site-nav__progress span {
    display: block;
    width: 1px;
    height: 3px;
    background: var(--color-line-soft);
    transition: background-color 160ms var(--ease-ui);
  }

  .site-nav__progress span:nth-child(6n + 1) {
    height: 4px;
  }

  .site-nav__progress span.is-filled {
    background: var(--color-ink-secondary);
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.13rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1;
    text-decoration: none;
  }

  .site-nav__desktop-links {
    display: flex;
    gap: clamp(1rem, 2.25vw, 2rem);
    margin-left: auto;
  }

  .site-nav__desktop-links a {
    color: var(--color-ink-secondary);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: color 160ms var(--ease-ui);
  }

  @media (hover: hover) and (pointer: fine) {
    .site-nav__desktop-links a:hover {
      color: var(--color-ink);
    }
  }

  .site-nav__cta {
    min-height: 40px;
    margin-left: clamp(1.25rem, 3vw, 2.75rem);
  }

  .site-nav__cta > span {
    padding: 10px 14px;
  }

  .site-nav__menu-button,
  .site-nav__close {
    border: 0;
    background: none;
    color: var(--color-ink);
    font-size: 15px;
    font-weight: 500;
  }

  .site-nav__menu-button {
    display: none;
    margin-left: auto;
  }

  .site-nav__mobile-menu[hidden] {
    display: none;
  }

  .site-nav__mobile-menu {
    position: fixed;
    inset: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    padding: max(20px, env(safe-area-inset-top)) var(--gutter)
      max(20px, env(safe-area-inset-bottom));
    background: var(--color-ground);
    opacity: 1;
    transition: opacity 200ms var(--ease-ui);
  }

  @starting-style {
    .site-nav__mobile-menu:not([hidden]) {
      opacity: 0;
    }
  }

  .site-nav__mobile-menu.is-closing {
    opacity: 0;
    transition-duration: 150ms;
  }

  .site-nav__close {
    justify-self: end;
    padding: 0.6rem 0;
  }

  .site-nav__mobile-links {
    display: grid;
    align-content: center;
    gap: 1.15rem;
    padding-bottom: 10vh;
  }

  .site-nav__mobile-links a {
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 11vw, 4.5rem);
    font-weight: 600;
    letter-spacing: var(--type-display-tracking);
    line-height: 1.03;
    text-decoration: none;
    transform: translateY(0);
    transition: transform 200ms var(--ease-ui);
  }

  .site-nav__mobile-menu:not([hidden]) .site-nav__mobile-links a {
    transition-delay: calc(var(--menu-link-index) * 30ms + 30ms);
  }

  @starting-style {
    .site-nav__mobile-menu:not([hidden]) .site-nav__mobile-links a {
      transform: translateY(14px);
    }
  }

  .site-nav__mobile-menu.is-closing .site-nav__mobile-links a {
    transform: translateY(8px);
    transition-duration: 150ms;
    transition-delay: 0ms;
  }

  @media (max-width: 759px) {
    .site-nav__desktop-links,
    .site-nav__cta {
      display: none;
    }

    .site-nav__menu-button {
      display: block;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav__progress span,
    .site-nav__mobile-menu,
    .site-nav__mobile-links a {
      transition: none;
    }
  }
</style>
