<style>
  .figure {
    width: 100%;
    height: 100%;
    color: var(--color-ink);
    overflow: visible;
  }

  .stroke,
  .stroke-soft {
    stroke-linecap: butt;
    stroke-linejoin: miter;
  }

  .stroke {
    stroke: currentColor;
    stroke-opacity: 0.55;
    stroke-width: 1.25px;
  }

  .stroke-soft {
    stroke: currentColor;
    stroke-opacity: 0.28;
    stroke-width: 1px;
  }

  /* Hidden-line convention: the wire inside the housing is dashed. */
  .dashed {
    stroke-dasharray: 4 3;
  }

  .amberfill {
    fill: currentColor;
  }

  .figure__label {
    fill: var(--color-ink-faint);
    font-family: var(--font-readout);
    font-size: 9px;
    font-weight: var(--type-readout-weight);
    letter-spacing: 0.1em;
  }

  .figure__pulse {
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.has-scroll-reveals) .figure:not(.is-drawn) .draw {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
    }

    :global(.has-scroll-reveals) .figure:not(.is-drawn) .fade {
      opacity: 0;
    }

    .figure.is-drawn .draw {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: figure-draw 800ms var(--ease-ui) forwards;
    }

    .figure.is-drawn .d2 {
      animation-delay: 250ms;
    }

    .figure.is-drawn .fade {
      animation: figure-fade 400ms var(--ease-ui) 600ms both;
    }

    /* One pulse rides the whole wire — jagged in, dimmed while inside the
       housing, bright and clean out. Ends dark on both sides of the loop. */
    .figure__pulse {
      animation: signal-travel 7s linear 1.6s infinite;
      animation-play-state: paused;
    }

    .figure.is-drawn.is-live .figure__pulse {
      animation-play-state: running;
    }
  }

  @keyframes figure-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes figure-fade {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  @keyframes signal-travel {
    0% {
      offset-distance: 0%;
      opacity: 0;
    }

    4% {
      opacity: 1;
    }

    38.7% {
      opacity: 1;
    }

    41% {
      opacity: 0.3;
    }

    66% {
      opacity: 0.3;
    }

    68.4% {
      opacity: 1;
    }

    90% {
      opacity: 1;
    }

    96%,
    100% {
      offset-distance: 100%;
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .figure,
    .figure * {
      animation: none !important;
    }

    /* Static state: the processed signal, already past the housing. */
    .figure__pulse {
      opacity: 1;
      offset-distance: 76%;
    }
  }

  @media print {
    .draw {
      animation: none !important;
      stroke-dasharray: none !important;
      stroke-dashoffset: 0 !important;
    }

    .fade {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>
