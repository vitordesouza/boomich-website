</svg>

<style>
  .figure {
    width: 100%;
    height: 100%;
    color: var(--color-ink);
    overflow: visible;
  }

  .stroke,
  .stroke-soft {
    stroke-linecap: butt;
    stroke-linejoin: miter;
  }

  .stroke {
    stroke: currentColor;
    stroke-opacity: 0.55;
    stroke-width: 1.25px;
  }

  .stroke-soft {
    stroke: currentColor;
    stroke-opacity: 0.28;
    stroke-width: 1px;
  }

  /* Hidden-line convention: the seam is dashed inside plate material. */
  .dashed {
    stroke-dasharray: 4 3;
  }

  .amberfill {
    fill: currentColor;
  }

  /* The bulge: erasers open the tube walls locally, the bowed arcs close
     them again around the ball — the tube stretches around its load. */
  .eraser {
    stroke: var(--color-ground-recessed);
    stroke-width: 3.5px;
  }

  .figure__load,
  .figure__bulge {
    opacity: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.has-scroll-reveals) .figure:not(.is-drawn) .draw {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
    }

    :global(.has-scroll-reveals) .figure:not(.is-drawn) .fade {
      opacity: 0;
    }

    .figure.is-drawn .draw {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: figure-draw 800ms var(--ease-ui) forwards;
    }

    .figure.is-drawn .d2 {
      animation-delay: 250ms;
    }

    .figure.is-drawn .fade {
      animation: figure-fade 400ms var(--ease-ui) 600ms both;
    }

    .figure__load {
      animation: seam-ball 11s linear 1.6s infinite;
      animation-play-state: paused;
    }

    .figure__bulge {
      animation: seam-bulge 11s linear 1.6s infinite;
      animation-play-state: paused;
    }

    .figure.is-drawn.is-live :is(.figure__load, .figure__bulge) {
      animation-play-state: running;
    }
  }

  @keyframes figure-draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes figure-fade {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  /* The ball drops into the mouth, dims through each plate's thickness
     (19.1–24.2% and 52.6–57.6% — computed from the geometry), and sinks
     into the base plate. Both loop endpoints are dark: no restart flick. */
  @keyframes seam-ball {
    0% {
      transform: translateY(-14px);
      opacity: 0;
    }

    4% {
      opacity: 0;
    }

    8% {
      transform: translateY(0);
      opacity: 1;
    }

    19.1% {
      opacity: 1;
    }

    20.4% {
      opacity: 0.35;
    }

    22.9% {
      opacity: 0.35;
    }

    24.2% {
      opacity: 1;
    }

    52.6% {
      opacity: 1;
    }

    53.9% {
      opacity: 0.35;
    }

    56.3% {
      opacity: 0.35;
    }

    57.6% {
      opacity: 1;
    }

    86% {
      transform: translateY(140px);
      opacity: 1;
    }

    91%,
    100% {
      transform: translateY(148px);
      opacity: 0;
    }
  }

  @keyframes seam-bulge {
    0% {
      transform: translateY(-14px);
      opacity: 0;
    }

    7% {
      opacity: 0;
    }

    8% {
      transform: translateY(0);
    }

    10% {
      opacity: 1;
    }

    19.1% {
      opacity: 1;
    }

    20.1% {
      opacity: 0;
    }

    23.2% {
      opacity: 0;
    }

    24.2% {
      opacity: 1;
    }

    52.6% {
      opacity: 1;
    }

    53.6% {
      opacity: 0;
    }

    56.6% {
      opacity: 0;
    }

    57.6% {
      opacity: 1;
    }

    84% {
      opacity: 1;
    }

    86% {
      transform: translateY(140px);
    }

    88% {
      opacity: 0;
    }

    91%,
    100% {
      transform: translateY(148px);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .figure,
    .figure * {
      animation: none !important;
    }

    /* Static state: the load waits at the mouth of the seam. */
    .figure__load {
      opacity: 1;
    }
  }

  @media print {
    .draw {
      animation: none !important;
      stroke-dasharray: none !important;
      stroke-dashoffset: 0 !important;
    }

    .fade {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>
