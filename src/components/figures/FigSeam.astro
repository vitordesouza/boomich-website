      pathLength="1"
      d="M251.8 114 L160 61 L68.2 114"></path>
    <path
      class="stroke draw"
      pathLength="1"
      d="M251.8 114 L251.8 123 L160 176 L68.2 123 L68.2 114"></path>
    <path class="stroke draw d2" pathLength="1" d="M160 167 L160 176"></path>
    <path class="stroke-soft draw d2" pathLength="1" d="M229.3 127 L229.3 136"
    ></path>
    <path
