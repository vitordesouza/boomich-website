---
interface Props {
  /** Kept for call-site compatibility; the silhouette is size-stable. */
  small?: boolean;
  size?: number;
  class?: string;
}

const { size = 32, class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 100 100"
  width={size}
  height={size}
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  focusable="false"
>
  <path
    fill="currentColor"
    fill-rule="evenodd"
    d="M20 4 L85.5 27.2 Q88 28.3 88 30.2 Q88 32.1 85.5 33.2 L45 50 L85.5 65.2 Q88 66.4 88 68.3 Q88 70.2 85.5 71.3 L20 96 V53 Q20 52 23.5 50.5 Q20 49 20 47 V4 Z M30 19 L64 30.5 L30 45 Z M30 53 L64 68 L30 82 Z"
  ></path>
</svg>
