---
import { site } from '../content/site';
import FigCore from './figures/FigCore.astro';
import FigSeam from './figures/FigSeam.astro';
import FigSignal from './figures/FigSignal.astro';

const figures = [
  { Figure: FigCore, label: 'FIG. 01 — SHARED CORE' },
  { Figure: FigSignal, label: 'FIG. 02 — SIGNAL PATH' },
  { Figure: FigSeam, label: 'FIG. 03 — THE SEAM' },
];
---

<section
  id="capabilities"
  class="capabilities"
  aria-labelledby="capabilities-heading"
>
  <div class="capabilities__inner">
    <h2 id="capabilities-heading">{site.capabilities.heading}</h2>
    <div class="capabilities__rows">
      {
        site.capabilities.items.map((item, index) => {
          const { Figure, label } = figures[index];
          return (
            <article
              class="spec-row"
              data-capability-reveal
              style={`--reveal-delay: ${index * 60}ms`}
            >
              <div class="spec-row__plate">
                <Figure />
                <span class="spec-row__plate-label">{label}</span>
              </div>
              <div class="spec-row__content">
                <h3>{item.title}</h3>
                <p>{item.body}</p>
                <ul aria-label={`${item.title} technologies`}>
                  {item.tags.map((tag) => (
                    <li>{tag}</li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .capabilities {
    padding: var(--section) var(--gutter);
    border-top: 1px solid var(--color-line);
  }

  .capabilities__inner {
    width: min(100%, var(--maxw));
    margin: 0 auto;
  }

  h2,
  h3,
  p {
    margin: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: var(--type-headline-size);
    font-weight: var(--type-headline-weight);
    letter-spacing: var(--type-headline-tracking);
    line-height: var(--type-headline-leading);
  }

  .capabilities__rows {
    margin-top: clamp(2.25rem, 5vw, 4rem);
  }

  /* Each capability is a drawing sheet: the figure on its recessed plate,
     its subject beside it. Plates alternate sides so the section reads as
     a sequence, not a table. */
  .spec-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
    padding: clamp(2rem, 4vw, 3.25rem) 0;
    column-gap: clamp(2.5rem, 6vw, 5.5rem);
    row-gap: 1.5rem;
  }

  .spec-row:nth-of-type(even) .spec-row__plate {
    order: 2;
  }

  .spec-row::before {
    position: absolute;
    top: -1px;
    right: 0;
    left: 0;
    height: 1px;
    background: var(--color-line);
    content: '';
    transform-origin: left;
  }

  .spec-row:last-child::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: var(--color-line);
    content: '';
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.has-scroll-reveals) .spec-row[data-capability-reveal] {
      opacity: 0;
      transform: translateY(14px);
      transition:
        opacity 500ms var(--ease-ui) var(--reveal-delay, 0ms),
        transform 500ms var(--ease-ui) var(--reveal-delay, 0ms);
    }

    :global(.has-scroll-reveals) .spec-row[data-capability-reveal]::before {
      transform: scaleX(0);
      transition: transform 450ms var(--ease-ui) var(--reveal-delay, 0ms);
    }

    :global(.has-scroll-reveals) .spec-row[data-capability-reveal].is-revealed {
      opacity: 1;
      transform: translateY(0);
    }

    :global(
      .has-scroll-reveals .spec-row[data-capability-reveal].is-revealed::before
    ) {
      transform: scaleX(1);
    }
  }

  .spec-row__plate {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    padding: clamp(1.25rem, 2.5vw, 2rem);
    padding-bottom: clamp(2.25rem, 4vw, 2.75rem);
    border: 1px solid var(--color-line);
    background: var(--color-ground-recessed);
  }

  .spec-row__plate-label {
    position: absolute;
    bottom: 0.85rem;
    left: 1rem;
    color: var(--color-ink-faint);
    font-family: var(--font-readout);
    font-size: 10px;
    font-weight: var(--type-readout-weight);
    letter-spacing: 0.08em;
  }

  .spec-row__content {
    display: grid;
    gap: 1.15rem;
    max-width: 46ch;
  }

  .spec-row h3 {
    font-size: clamp(1.15rem, 1rem + 0.8vw, 1.45rem);
    font-weight: 600;
    line-height: 1.3;
  }

  .spec-row p {
    color: var(--color-ink-secondary);
  }

  .spec-row ul,
  .spec-row li {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .spec-row ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: 0.35rem;
  }

  .spec-row li {
    padding: 0.33rem 0.5rem;
    border: 1px solid var(--color-line);
    color: var(--color-ink-secondary);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
  }

  @media (max-width: 899px) {
    .spec-row {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }

    /* Figure first on a single column: it draws the eye, the text answers. */
    .spec-row:nth-of-type(even) .spec-row__plate {
      order: 0;
    }

    .spec-row__content {
      max-width: 55ch;
    }
  }
</style>
