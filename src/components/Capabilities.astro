---
import { site } from '../content/site';
import FigCore from './figures/FigCore.astro';
import FigSeam from './figures/FigSeam.astro';
import FigSignal from './figures/FigSignal.astro';

const figures = [FigCore, FigSignal, FigSeam];
---

<section
  id="capabilities"
  class="capabilities"
  aria-labelledby="capabilities-heading"
>
  <div class="capabilities__inner">
    <h2 id="capabilities-heading">{site.capabilities.heading}</h2>
    <div class="capabilities__rows">
      {
        site.capabilities.items.map((item, index) => (
          <article
            class="spec-row"
            data-capability-reveal
            style={`--reveal-delay: ${index * 60}ms`}
          >
            <h3>{item.title}</h3>
            <div class="spec-row__figure">
              {(() => {
                const Figure = figures[index];
                return <Figure />;
              })()}
            </div>
            <div class="spec-row__content">
              <p>{item.body}</p>
              <ul aria-label={`${item.title} technologies`}>
                {item.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .capabilities {
    padding: var(--section) var(--gutter);
    border-top: 1px solid var(--color-line);
  }

  .capabilities__inner {
    width: min(100%, var(--maxw));
    margin: 0 auto;
  }

  h2,
  h3,
  p {
    margin: 0;
  }

  h2 {
    font-family: var(--font-display);
    font-size: var(--type-headline-size);
    font-weight: var(--type-headline-weight);
    letter-spacing: var(--type-headline-tracking);
    line-height: var(--type-headline-leading);
  }

  .capabilities__rows {
    margin-top: clamp(2.25rem, 5vw, 4.5rem);
  }

  .spec-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(11rem, 0.65fr) minmax(0, 1.25fr) minmax(
        12rem,
        14.375rem
      );
    gap: 1.5rem clamp(1.5rem, 4vw, 4rem);
    align-items: center;
    padding: clamp(1.5rem, 3.5vw, 2.5rem) 0;
    transition: background-color 160ms var(--ease-ui);
  }

  .spec-row::before {
    position: absolute;
    top: -1px;
    right: 0;
    left: 0;
    height: 1px;
    background: var(--color-line);
    content: '';
    transform-origin: left;
  }

  .spec-row:last-child::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: var(--color-line);
    content: '';
  }

  @media (prefers-reduced-motion: no-preference) {
    :global(.has-scroll-reveals) .spec-row[data-capability-reveal] {
      opacity: 0;
      transform: translateY(14px);
      transition:
        opacity 500ms var(--ease-ui) var(--reveal-delay, 0ms),
        transform 500ms var(--ease-ui) var(--reveal-delay, 0ms);
    }

    :global(.has-scroll-reveals) .spec-row[data-capability-reveal]::before {
      transform: scaleX(0);
      transition: transform 450ms var(--ease-ui) var(--reveal-delay, 0ms);
    }

    :global(.has-scroll-reveals) .spec-row[data-capability-reveal].is-revealed {
      opacity: 1;
      transform: translateY(0);
    }

    :global(
      .has-scroll-reveals .spec-row[data-capability-reveal].is-revealed::before
    ) {
      transform: scaleX(1);
    }
  }

  .spec-row h3 {
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .spec-row__content {
    display: grid;
    gap: 1.25rem;
  }

  .spec-row p {
    max-width: 55ch;
    color: var(--color-ink-secondary);
  }

  .spec-row ul,
  .spec-row li {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .spec-row ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .spec-row__figure {
    width: min(100%, 230px);
  }

  /* The signal figure is wide-aspect; give it more run so its machine
     reads at the same visual weight as the other figures. */
  .spec-row:nth-of-type(2) .spec-row__figure {
    width: min(100%, 300px);
    justify-self: end;
  }

  .spec-row li {
    padding: 0.33rem 0.5rem;
    border: 1px solid var(--color-line);
    color: var(--color-ink-secondary);
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.2;
  }

  @media (hover: hover) and (pointer: fine) {
    .spec-row:hover {
      background: var(--color-ground-raised);
    }
  }

  @media (max-width: 979px) {
    .spec-row {
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }

    .spec-row__figure {
      width: min(100%, 260px);
      justify-self: start;
    }
  }

  @media (max-width: 560px) {
    .spec-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
