---
import { site } from '../content/site';
import Instrument from './Instrument.astro';
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero__inner">
    <div class="hero__copy">
      <h1 id="hero-heading">{site.hero.title}</h1>
      <p class="hero__summary">{site.hero.summary}</p>
      <div class="hero__actions">
        <a class="button-primary" href={site.hero.primaryCta.href}
          ><span>{site.hero.primaryCta.label}</span></a
        >
        <a class="button-ghost" href={site.hero.secondaryCta.href}
          ><span>{site.hero.secondaryCta.label}</span></a
        >
      </div>
    </div>
    <Instrument />
  </div>
</section>

<style>
  .hero {
    padding: clamp(50px, 7vw, 92px) var(--gutter) clamp(56px, 7vw, 88px);
  }

  .hero__inner {
    display: grid;
    width: min(100%, var(--maxw));
    margin: 0 auto;
    gap: clamp(3rem, 7vw, 7rem);
  }

  .hero__copy {
    min-width: 0;
    display: grid;
    align-content: center;
    justify-items: start;
  }

  h1,
  p {
    margin: 0;
  }

  h1 {
    max-width: 12.75ch;
    font-family: var(--font-display);
    font-size: var(--type-display-size);
    font-weight: var(--type-display-weight);
    letter-spacing: var(--type-display-tracking);
    line-height: var(--type-display-leading);
    text-wrap: balance;
    overflow-wrap: break-word;
  }

  .hero__summary {
    max-width: 34ch;
    margin-top: 1.65rem;
    color: var(--color-ink-secondary);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
  }

  @media (min-width: 980px) {
    .hero {
      min-height: min(760px, calc(100svh - 72px));
      display: grid;
      align-items: center;
    }

    .hero__inner {
      grid-template-columns: minmax(0, 1.15fr) minmax(360px, 0.85fr);
      align-items: center;
      gap: clamp(2rem, 3.5vw, 3.5rem);
    }
  }

  @media (max-width: 370px) {
    h1 {
      font-size: clamp(2.25rem, 12.7vw, 2.5rem);
    }

    .hero__actions > a {
      width: 100%;
    }
  }
</style>
