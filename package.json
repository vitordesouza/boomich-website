{
  "name": "boomich",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "icons:generate": "node scripts/icons.mjs",
    "og:generate": "pnpm build && node scripts/generate-og.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm format:check && pnpm lint && ASTRO_TELEMETRY_DISABLED=1 pnpm exec astro check && pnpm test && pnpm build",
    "prepare": "node scripts/install-hooks.mjs"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.4",
    "@astrojs/sitemap": "^3.7.3",
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.10.1",
    "astro": "5.18.2",
    "eslint": "10.7.0",
    "eslint-plugin-astro": "2.1.1",
    "globals": "16.5.0",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "sharp": "^0.35.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "lenis": "^1.3.25",
    "motion": "^12.42.2"
  }
}
